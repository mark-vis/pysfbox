// Weak charges regression 3: the shipped Namics example polE.in verbatim
// (weak polyelectrolyte (A)100 restricted + pinned anchor (X)1(A)5 at an
// adsorbing wall chi_S = -6; 3-state water; pK_a 7, pK_w 14, pH 7), plus
// state-resolved outputs. Validated against the compiled Namics on
// 5 Jul 2026: phi profiles at the convergence floor (~1e-10 relative) in
// the physically meaningful region; F to the oracle's printed 6 digits
// (-19.4611), GP -0.0808676 exact. KNOWN INTENTIONAL DEVIATION: the
// oracle's far-field tail carries a spurious e^{+kappa z} screening mode
// pinned at the upper mirror (its ghost layer holds garbage charge,
// q_ghost = -1135 in the shipped run, feeding the last Poisson row);
// PySFBox implements the clean zero-flux mirror, so phi/psi tails at the
// 1e-8 absolute level differ from the unpatched oracle (max ~8e-4
// relative AT the boundary, <8e-12 absolute). See
// the Namics bug reports shared with the authors.
// (polE.in's 'mon : A : valence : -1' is dead input -- states carry the
// charge -- and triggers a PySFBox warning; kept verbatim anyway.)
lat : flat : geometry : planar
lat : flat : n_layers : 30
lat : flat : gradients : 1
lat : flat : lattice_type : simple_cubic
lat : flat : lowerbound : surface
lat : flat : bondlength : 3e-10

mon : S : freedom : frozen
mon : S : frozen_range : lowerbound;

mon : W : freedom : free
mon : A : freedom : free
mon : A : valence : -1
mon : Na : freedom : free
mon : Cl : freedom : free
mon : Na : valence : 1
mon : Cl : valence : -1
mon : X : valence : 1
mon : X : freedom : pinned
mon : X : pinned_range : firstlayer

state : AH : valence : 0
state : AH : mon : A
state : AM : valence : -1
state : AM : mon : A

state : H3O : valence : 1
state : H2O : valence : 0
state : OH : valence : -1

state : H3O : mon : W
state : H2O : mon : W
state : OH  : mon : W

mon : A : chi_S : -6

reaction : weak : equation : 1(AH) + 1(H2O) = 1(AM) + 1(H3O)
reaction : weak : pK : 7

reaction : auto : equation : 2(H2O) = 1(OH) + 1(H3O)
reaction : auto : pK : 14

state : H3O : alphabulk : 1e-7

mol : water : composition : (W)1
mol : water : freedom : solvent

mol : pol  : composition : (A)100
mol : pol : freedom : restricted
mol : pol : theta : 0.2

mol : X : composition : (X)1(A)5
mol : X : freedom : restricted
mol : X : theta : 0.1

mol : Na : composition  : (Na)1
mol : Na : freedom : neutralizer

mol : Cl : composition : (Cl)1
mol : Cl : freedom : free
mol : Cl : phibulk : 0.1

output : kal : append : false
kal : mon : A : theta_AM
kal : mon : A : theta_AH
kal : mon : A : alphabulk_AM
kal : mol : Na : phibulk
kal : sys : NN : free_energy
kal : sys : NN : grand_potential

output : pro : append : false
pro : mol : pol : phi
pro : mon : A : phi
pro : mon : A : phi-AM
pro : mon : A : alpha-AM
pro : mon : Na : phi
pro : mon : Cl : phi
pro : sys : NN : psi
pro : sys : NN : q

newton : isaac : tolerance : 1e-10

start
