// Weak charges regression 2: charge-regulation TITRATION of a pinned
// monomeric weak acid (pK 7) at an uncharged wall in 0.01 salt, scanning
// alphabulk_H3O exponentially over 1e-9..1e-5 (2 steps per decade -> 9
// rows; Namics 'steps' semantics for exponential scans is steps PER
// DECADE, state.cpp:268-304). The full 73-row version of this curve was
// validated against the compiled Namics on 5 Jul 2026 at the shared
// convergence floor: theta_AM 3e-11, free energy 4e-11, grand potential
// 4e-11 relative (against the compiled Namics). The curve
// asymptotes to Henderson-Hasselbalch at low ionisation and is
// regulation-suppressed at high pH. The charge-regulation identity
// alpha_AM/alpha_AH = (bulk ratio) * exp(+psi(z)) holds pointwise to
// machine epsilon at every converged step.
lat : flat : geometry : planar
lat : flat : n_layers : 30
lat : flat : gradients : 1
lat : flat : lattice_type : simple_cubic
lat : flat : lowerbound : surface
lat : flat : bondlength : 3e-10

mon : S : freedom : frozen
mon : S : frozen_range : lowerbound

mon : W : freedom : free
mon : A : freedom : pinned
mon : A : pinned_range : 1;1
mon : Na : freedom : free
mon : Na : valence : 1
mon : Cl : freedom : free
mon : Cl : valence : -1

state : AH : valence : 0
state : AH : mon : A
state : AM : valence : -1
state : AM : mon : A

state : H3O : valence : 1
state : H3O : mon : W
state : H2O : valence : 0
state : H2O : mon : W
state : OH : valence : -1
state : OH : mon : W

reaction : weak : equation : 1(AH) + 1(H2O) = 1(AM) + 1(H3O)
reaction : weak : pK : 7

reaction : auto : equation : 2(H2O) = 1(OH) + 1(H3O)
reaction : auto : pK : 14

state : H3O : alphabulk : 1e-9

mol : water : composition : (W)1
mol : water : freedom : solvent

mol : acid : composition : (A)1
mol : acid : freedom : restricted
mol : acid : theta : 0.2

mol : Na : composition : (Na)1
mol : Na : freedom : neutralizer

mol : Cl : composition : (Cl)1
mol : Cl : freedom : free
mol : Cl : phibulk : 0.01

output : kal : append : false
kal : mon : W : alphabulk_H3O
kal : mon : A : theta_AM
kal : mon : A : theta_AH
kal : mol : Na : phibulk
kal : sys : NN : free_energy
kal : sys : NN : grand_potential

var : state-H3O : scan : alphabulk
var : state-H3O : scale : exponential
var : state-H3O : steps : 2
var : state-H3O : end_value : 1e-5

newton : isaac : tolerance : 1e-10

start
